{
  "name": "disk-manager",
  "version": "1.0.0",
  "description": "Disk Manager — diskpart GUI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.diskmanager.app",
    "productName": "Disk Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "disk-manager.html"
    ],
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  },
  "dependencies": {
    "build": "^0.1.4"
  }
}
